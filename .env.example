# Copy this to .env and fill in real values
# NEVER commit .env to Git

FLASK_ENV=production
SECRET_KEY=CHANGE_ME_use_a_long_random_string_here

DB_USER=postgres.xxxxxxxxxxxxx
DB_PASSWORD=xxxxxxxxxxxxx
DB_HOST=aws-x-ap-northeast-x.pooler.supabase.com
DB_PORT=xxxx
DB_NAME=xxxxxxxxxx

ENCRYPTION_KEY=CHANGE_ME_32_byte_base64_encoded_key

MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,csv

SESSION_LIFETIME_MINUTES=30
MFA_ISSUER=PersonalFinanceTracker

# URL of the frontend (used for CORS). Set to your Vercel URL in production.
FRONTEND_URL=http://localhost:5173

# Mail server (used for email verification and password reset)
MAIL_SERVER=smtp.example.com
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=CHANGE_ME

SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_BUCKET=bank-statements
